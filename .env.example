# Copy to .env.local and fill in (see docs/DEPLOYMENT.md)

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Hardcoded global admins (comma-separated Gmail addresses)
ADMIN_EMAILS=you@gmail.com

# Name of the apex space auto-created for every Parva (optional; default "HSS USA")
NATIONAL_SPACE_NAME=HSS USA

# Cloudflare R2 (private media bucket)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gokul-glimpses-dev

# App origin (http://localhost:3000 locally, https://your-domain in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000
